---
interface Props {
  title: string;
  description: string;
  date: string;
  slug: string;
  readingTime?: string;
}

const { title, description, date, slug, readingTime } = Astro.props;

const formattedDate = new Date(date).toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});
---

<a href={`/blog/${slug}`} class="block group">
  <article class="bg-gray-900/50 border border-gray-800 rounded-xl p-6
                  transition-all duration-300 ease-out
                  hover:border-accent/40 hover:bg-gray-900/80 hover:-translate-y-1
                  hover:shadow-lg hover:shadow-accent/10">
    <div class="flex items-center gap-3 text-xs text-gray-500 mb-3">
      <time datetime={date}>{formattedDate}</time>
      {readingTime && (
        <>
          <span class="w-1 h-1 rounded-full bg-gray-600"></span>
          <span>{readingTime}</span>
        </>
      )}
    </div>

    <h3 class="text-lg font-semibold text-gray-100 mb-2 group-hover:text-accent-light transition-colors duration-300">
      {title}
    </h3>

    <p class="text-gray-400 text-sm leading-relaxed line-clamp-3">
      {description}
    </p>

    <div class="mt-4 flex items-center gap-1 text-sm text-accent group-hover:text-accent-light transition-colors duration-300">
      <span>Read more</span>
      <svg class="w-4 h-4 transition-transform duration-300 group-hover:translate-x-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
      </svg>
    </div>
  </article>
</a>
