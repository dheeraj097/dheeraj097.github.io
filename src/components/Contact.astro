---
import { siteConfig } from '../lib/site';
---

<section id="contact" class="scroll-mt-20 py-16 sm:py-24">
  <div class="container-section">
    <div class="mb-12 max-w-2xl">
      <p class="mb-3 text-sm font-semibold uppercase tracking-widest text-brand-600 dark:text-brand-400">Contact</p>
      <h2 class="section-heading">Let's build something great</h2>
    </div>

    <div class="overflow-hidden rounded-3xl border border-slate-200/70 bg-gradient-to-br from-brand-600 to-brand-900 p-8 text-white sm:p-12 dark:border-white/10">
      <div class="grid items-center gap-8 lg:grid-cols-2">
        <div>
          <h3 class="text-2xl font-bold sm:text-3xl">Have a project in mind?</h3>
          <p class="mt-3 max-w-md text-brand-100">
            I'm currently available for freelance and consulting work.
            Tell me about your idea and let's make it real.
          </p>
          <a
            href={siteConfig.social.email}
            class="mt-6 inline-flex items-center gap-2 rounded-lg bg-white px-6 py-3 text-sm font-semibold text-brand-700 transition-colors hover:bg-brand-50"
          >
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="h-5 w-5" aria-hidden="true">
              <rect width="20" height="16" x="2" y="4" rx="2" />
              <path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7" />
            </svg>
            {siteConfig.email}
          </a>
        </div>

        <ul class="grid gap-3 sm:grid-cols-2">
          <li>
            <a href={siteConfig.social.github} target="_blank" rel="noopener noreferrer" class="flex items-center gap-3 rounded-xl bg-white/10 px-4 py-3 font-medium transition-colors hover:bg-white/20">
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="h-5 w-5" aria-hidden="true">
                <path d="M12 .5a12 12 0 0 0-3.79 23.4c.6.11.82-.26.82-.58v-2c-3.34.73-4.04-1.61-4.04-1.61-.55-1.39-1.34-1.76-1.34-1.76-1.09-.75.08-.73.08-.73 1.2.08 1.84 1.24 1.84 1.24 1.07 1.83 2.81 1.3 3.5.99.11-.78.42-1.3.76-1.6-2.67-.3-5.47-1.33-5.47-5.93 0-1.31.47-2.38 1.24-3.22-.13-.3-.54-1.52.12-3.18 0 0 1.01-.32 3.3 1.23a11.5 11.5 0 0 1 6 0c2.29-1.55 3.3-1.23 3.3-1.23.66 1.66.25 2.88.12 3.18.77.84 1.23 1.91 1.23 3.22 0 4.61-2.8 5.63-5.48 5.92.43.37.81 1.1.81 2.22v3.29c0 .32.22.7.83.58A12 12 0 0 0 12 .5z" />
              </svg>
              GitHub
            </a>
          </li>
          <li>
            <a href={siteConfig.social.linkedin} target="_blank" rel="noopener noreferrer" class="flex items-center gap-3 rounded-xl bg-white/10 px-4 py-3 font-medium transition-colors hover:bg-white/20">
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="h-5 w-5" aria-hidden="true">
                <path d="M20.45 20.45h-3.56v-5.57c0-1.33-.03-3.04-1.85-3.04-1.86 0-2.14 1.45-2.14 2.94v5.67H9.34V9h3.42v1.56h.05c.48-.9 1.64-1.85 3.37-1.85 3.6 0 4.27 2.37 4.27 5.45v6.29zM5.34 7.43a2.06 2.06 0 1 1 0-4.13 2.06 2.06 0 0 1 0 4.13zM7.12 20.45H3.55V9h3.57v11.45zM22.22 0H1.77C.79 0 0 .77 0 1.73v20.54C0 23.23.79 24 1.77 24h20.45c.98 0 1.78-.77 1.78-1.73V1.73C24 .77 23.2 0 22.22 0z" />
              </svg>
              LinkedIn
            </a>
          </li>
          <li>
            <a href={siteConfig.social.twitter} target="_blank" rel="noopener noreferrer" class="flex items-center gap-3 rounded-xl bg-white/10 px-4 py-3 font-medium transition-colors hover:bg-white/20">
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="h-5 w-5" aria-hidden="true">
                <path d="M18.9 1.15h3.68l-8.04 9.19L24 22.85h-7.41l-5.8-7.58-6.64 7.58H.46l8.6-9.83L0 1.15h7.59l5.24 6.93 6.07-6.93zm-1.29 19.5h2.04L6.49 3.24H4.3l13.31 17.41z" />
              </svg>
              Twitter / X
            </a>
          </li>
          <li>
            <a href={siteConfig.social.email} class="flex items-center gap-3 rounded-xl bg-white/10 px-4 py-3 font-medium transition-colors hover:bg-white/20">
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="h-5 w-5" aria-hidden="true">
                <rect width="20" height="16" x="2" y="4" rx="2" />
                <path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7" />
              </svg>
              Email
            </a>
          </li>
        </ul>
      </div>
    </div>
  </div>
</section>
