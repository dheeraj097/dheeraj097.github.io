---
import { experiences } from '../lib/content';
---

<section id="experience" class="scroll-mt-20 py-16 sm:py-24">
  <div class="container-section">
    <div class="mb-12 max-w-2xl">
      <p class="mb-3 text-sm font-semibold uppercase tracking-widest text-brand-600 dark:text-brand-400">Experience</p>
      <h2 class="section-heading">A decade of building for the web</h2>
      <p class="mt-4 text-lg text-slate-600 dark:text-slate-300">
        A snapshot of the roles and impact across my career.
      </p>
    </div>

    <ol class="relative space-y-10 border-l border-slate-200 pl-8 dark:border-white/10">
      {experiences.map((exp) => (
        <li class="relative">
          <span class="absolute -left-[37px] top-1.5 flex h-4 w-4 items-center justify-center rounded-full border-2 border-brand-500 bg-white dark:bg-slate-950">
            <span class="h-1.5 w-1.5 rounded-full bg-brand-500"></span>
          </span>
          <div class="flex flex-wrap items-baseline justify-between gap-2">
            <h3 class="text-xl font-semibold text-slate-900 dark:text-white">
              {exp.role}
              <span class="text-brand-600 dark:text-brand-400"> · {exp.company}</span>
            </h3>
            <span class="text-sm font-medium text-slate-500 dark:text-slate-400">
              {exp.period}
            </span>
          </div>
          <p class="mt-2 text-slate-600 dark:text-slate-300">{exp.description}</p>
          <ul class="mt-3 space-y-2">
            {exp.highlights.map((highlight) => (
              <li class="flex items-start gap-2 text-slate-600 dark:text-slate-300">
                <span class="mt-2 h-1.5 w-1.5 flex-none rounded-full bg-brand-500"></span>
                {highlight}
              </li>
            ))}
          </ul>
        </li>
      ))}
    </ol>
  </div>
</section>
