---
import { siteConfig } from '../lib/site';
import { navItems } from '../lib/content';

const year = new Date().getFullYear();
---

<footer class="border-t border-slate-200/70 py-10 dark:border-white/10">
  <div class="container-section flex flex-col items-center justify-between gap-6 sm:flex-row">
    <div class="flex items-center gap-2 font-bold">
      <span class="inline-flex h-8 w-8 items-center justify-center rounded-lg bg-brand-600 text-sm font-extrabold text-white">
        DD
      </span>
      {siteConfig.name}
    </div>

    <nav aria-label="Footer">
      <ul class="flex flex-wrap justify-center gap-4 text-sm text-slate-500 dark:text-slate-400">
        {navItems.map((item) => (
          <li>
            <a href={item.href} class="transition-colors hover:text-brand-600 dark:hover:text-brand-400">
              {item.label}
            </a>
          </li>
        ))}
      </ul>
    </nav>

    <p class="text-sm text-slate-500 dark:text-slate-400">
      &copy; {year} {siteConfig.name}. All rights reserved.
    </p>
  </div>
</footer>
