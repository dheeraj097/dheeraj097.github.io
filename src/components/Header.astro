---
import { navItems } from '../lib/content';
import { siteConfig } from '../lib/site';
import ThemeToggle from './ThemeToggle.astro';
---

<header
  id="site-header"
  class="sticky top-0 z-40 w-full border-b border-transparent transition-colors"
>
  <nav class="container-section flex h-16 items-center justify-between" aria-label="Primary">
    <a href="/#main" class="flex items-center gap-2 font-bold">
      <span class="inline-flex h-8 w-8 items-center justify-center rounded-lg bg-brand-600 text-sm font-extrabold text-white">
        DD
      </span>
      <span class="hidden sm:inline">{siteConfig.name}</span>
    </a>

    <ul class="hidden items-center gap-1 md:flex">
      {navItems.map((item) => (
        <li>
          <a
            href={item.href}
            class="rounded-lg px-3 py-2 text-sm font-medium text-slate-600 transition-colors hover:bg-slate-100 hover:text-slate-900 dark:text-slate-300 dark:hover:bg-white/10 dark:hover:text-white"
          >
            {item.label}
          </a>
        </li>
      ))}
    </ul>

    <div class="flex items-center gap-2">
      <a
        href="#contact"
        class="hidden rounded-lg bg-brand-600 px-4 py-2 text-sm font-semibold text-white transition-colors hover:bg-brand-700 sm:inline-block"
      >
        Hire me
      </a>
      <ThemeToggle />
      <button
        id="mobile-menu-btn"
        type="button"
        class="inline-flex h-9 w-9 items-center justify-center rounded-lg border border-slate-200 text-slate-700 md:hidden dark:border-white/10 dark:text-slate-200"
        aria-label="Toggle navigation menu"
        aria-expanded="false"
      >
        <svg
          id="menu-icon"
          xmlns="http://www.w3.org/2000/svg"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          class="h-5 w-5"
          aria-hidden="true"
        >
          <path d="M3 12h18M3 6h18M3 18h18" />
        </svg>
      </button>
    </div>
  </nav>

  <!-- Mobile menu -->
  <div
    id="mobile-menu"
    class="hidden border-t border-slate-200/70 bg-white/95 backdrop-blur md:hidden dark:border-white/10 dark:bg-slate-950/95"
  >
    <ul class="container-section flex flex-col py-2">
      {navItems.map((item) => (
        <li>
          <a
            href={item.href}
            class="mobile-nav-link block rounded-lg px-3 py-3 text-sm font-medium text-slate-700 hover:bg-slate-100 dark:text-slate-200 dark:hover:bg-white/10"
          >
            {item.label}
          </a>
        </li>
      ))}
    </ul>
  </div>
</header>

<script>
  const header = document.getElementById('site-header');
  const btn = document.getElementById('mobile-menu-btn');
  const menu = document.getElementById('mobile-menu');
  const icon = document.getElementById('menu-icon');

  window.addEventListener('scroll', () => {
    if (!header) return;
    if (window.scrollY > 8) {
      header.classList.add('border-slate-200/70', 'bg-white/80', 'backdrop-blur', 'dark:border-white/10', 'dark:bg-slate-950/80');
      header.classList.remove('border-transparent', 'bg-transparent');
    } else {
      header.classList.remove('border-slate-200/70', 'bg-white/80', 'backdrop-blur', 'dark:border-white/10', 'dark:bg-slate-950/80');
      header.classList.add('border-transparent', 'bg-transparent');
    }
  }, { passive: true });

  btn?.addEventListener('click', () => {
    const isOpen = !menu?.classList.contains('hidden');
    menu?.classList.toggle('hidden');
    btn.setAttribute('aria-expanded', String(!isOpen));
    if (icon) {
      icon.innerHTML = isOpen
        ? '<path d="M3 12h18M3 6h18M3 18h18" />'
        : '<path d="M18 6 6 18M6 6l12 12" />';
    }
  });

  document.querySelectorAll('.mobile-nav-link').forEach((link) => {
    link.addEventListener('click', () => {
      menu?.classList.add('hidden');
      btn?.setAttribute('aria-expanded', 'false');
      if (icon) icon.innerHTML = '<path d="M3 12h18M3 6h18M3 18h18" />';
    });
  });
</script>
