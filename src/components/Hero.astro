---
import { siteConfig } from '../lib/site';
import { stats } from '../lib/content';
---

<section class="relative overflow-hidden pt-16 sm:pt-24">
  <!-- Decorative gradient background -->
  <div aria-hidden="true" class="pointer-events-none absolute inset-0 -z-10">
    <div class="absolute left-1/2 top-[-10%] h-[480px] w-[480px] -translate-x-1/2 rounded-full bg-brand-500/20 blur-3xl"></div>
    <div class="absolute right-[-10%] top-1/3 h-[360px] w-[360px] rounded-full bg-brand-700/10 blur-3xl"></div>
  </div>

  <div class="container-section grid items-center gap-12 pb-16 sm:pb-24 lg:grid-cols-[1.4fr_1fr]">
    <div class="animate-fade-in-up">
      <p class="mb-4 inline-flex items-center gap-2 rounded-full border border-brand-200 bg-brand-50 px-3 py-1 text-sm font-medium text-brand-700 dark:border-brand-500/30 dark:bg-brand-500/10 dark:text-brand-300">
        <span class="relative flex h-2 w-2">
          <span class="absolute inline-flex h-full w-full animate-ping rounded-full bg-brand-500 opacity-75"></span>
          <span class="relative inline-flex h-2 w-2 rounded-full bg-brand-500"></span>
        </span>
        Available for new projects
      </p>

      <h1 class="text-4xl font-extrabold tracking-tight sm:text-5xl lg:text-6xl">
        Hi, I&apos;m {siteConfig.name}.
        <span class="block bg-gradient-to-r from-brand-500 to-brand-800 bg-clip-text text-transparent dark:from-brand-300 dark:to-brand-500">
          {siteConfig.role}
        </span>
      </h1>

      <p class="mt-6 max-w-xl text-lg text-slate-600 dark:text-slate-300">
        {siteConfig.tagline} I help teams turn ideas into reliable products —
        from clean, accessible interfaces to robust APIs and infrastructure.
      </p>

      <div class="mt-8 flex flex-wrap gap-3">
        <a
          href="#projects"
          class="rounded-lg bg-brand-600 px-6 py-3 text-sm font-semibold text-white shadow-sm transition-colors hover:bg-brand-700"
        >
          View my work
        </a>
        <a
          href="#contact"
          class="rounded-lg border border-slate-300 px-6 py-3 text-sm font-semibold text-slate-700 transition-colors hover:bg-slate-100 dark:border-white/15 dark:text-slate-200 dark:hover:bg-white/10"
        >
          Get in touch
        </a>
      </div>

      <dl class="mt-12 grid grid-cols-2 gap-6 sm:grid-cols-4">
        {stats.map((stat) => (
          <div>
            <dt class="sr-only">{stat.label}</dt>
            <dd>
              <span class="block text-3xl font-bold text-brand-600 dark:text-brand-400">
                {stat.value}
              </span>
              <span class="mt-1 block text-sm text-slate-500 dark:text-slate-400">
                {stat.label}
              </span>
            </dd>
          </div>
        ))}
      </dl>
    </div>

    <div class="relative mx-auto hidden lg:block">
      <div class="animate-float rounded-3xl border border-slate-200/70 bg-white/70 p-8 shadow-xl backdrop-blur dark:border-white/10 dark:bg-white/5">
        <div class="flex items-center gap-1.5">
          <span class="h-3 w-3 rounded-full bg-red-400"></span>
          <span class="h-3 w-3 rounded-full bg-yellow-400"></span>
          <span class="h-3 w-3 rounded-full bg-green-400"></span>
        </div>
        <pre class="mt-5 overflow-hidden text-sm leading-relaxed"><code class="font-mono text-slate-700 dark:text-slate-200">{`const dheeraj = {
  role: "Full Stack Dev",
  experience: 10, // years
  stack: [
    "React", "Next.js",
    "Node.js", "TypeScript",
    "PHP", "Laravel"
  ],
  shipsQuality: true,
};`}</code></pre>
      </div>
    </div>
  </div>
</section>
