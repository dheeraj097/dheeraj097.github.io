---
---

<div class="hero-icons-container absolute inset-0 overflow-hidden pointer-events-none" aria-hidden="true">
  <!-- Floating tech icons -->
  <div class="floating-icon" style="top: 8%; left: 5%; --delay: 0s; --duration: 6s;">
    <svg viewBox="0 0 48 48" class="w-10 h-10 text-cyan-400/20"><ellipse cx="24" cy="24" rx="20" ry="12" fill="none" stroke="currentColor" stroke-width="2"/><text x="24" y="28" text-anchor="middle" fill="currentColor" font-size="12" font-weight="bold" font-family="monospace">PHP</text></svg>
  </div>

  <div class="floating-icon" style="top: 15%; right: 10%; --delay: 1.2s; --duration: 7s;">
    <svg viewBox="0 0 48 48" class="w-12 h-12 text-blue-400/20"><circle cx="24" cy="24" r="4" fill="currentColor"/><ellipse cx="24" cy="24" rx="18" ry="7" fill="none" stroke="currentColor" stroke-width="1.5"/><ellipse cx="24" cy="24" rx="18" ry="7" fill="none" stroke="currentColor" stroke-width="1.5" transform="rotate(60 24 24)"/><ellipse cx="24" cy="24" rx="18" ry="7" fill="none" stroke="currentColor" stroke-width="1.5" transform="rotate(120 24 24)"/></svg>
  </div>

  <div class="floating-icon" style="top: 60%; left: 8%; --delay: 2.5s; --duration: 8s;">
    <svg viewBox="0 0 48 48" class="w-9 h-9 text-green-400/20"><path d="M24 6l16 9.2v18.4L24 42 8 33.6V15.2L24 6z" fill="none" stroke="currentColor" stroke-width="2"/><text x="24" y="28" text-anchor="middle" fill="currentColor" font-size="10" font-weight="bold" font-family="monospace">N</text></svg>
  </div>

  <div class="floating-icon" style="top: 75%; right: 12%; --delay: 0.8s; --duration: 6.5s;">
    <svg viewBox="0 0 48 48" class="w-10 h-10 text-yellow-400/20"><rect x="8" y="8" width="32" height="32" rx="4" fill="none" stroke="currentColor" stroke-width="2"/><text x="24" y="30" text-anchor="middle" fill="currentColor" font-size="14" font-weight="bold" font-family="monospace">JS</text></svg>
  </div>

  <div class="floating-icon" style="top: 25%; left: 18%; --delay: 3.2s; --duration: 7.5s;">
    <svg viewBox="0 0 48 48" class="w-8 h-8 text-purple-400/20"><ellipse cx="24" cy="14" rx="14" ry="6" fill="none" stroke="currentColor" stroke-width="2"/><path d="M10 14v20c0 3.3 6.3 6 14 6s14-2.7 14-6V14" fill="none" stroke="currentColor" stroke-width="2"/><path d="M10 24c0 3.3 6.3 6 14 6s14-2.7 14-6" fill="none" stroke="currentColor" stroke-width="2"/></svg>
  </div>

  <div class="floating-icon" style="top: 40%; right: 5%; --delay: 1.8s; --duration: 6.8s;">
    <svg viewBox="0 0 48 48" class="w-11 h-11 text-red-400/20"><path d="M12 14l12-6 12 6v18l-12 6-12-6V14z" fill="none" stroke="currentColor" stroke-width="2"/><path d="M24 8v28M12 14l12 6 12-6" fill="none" stroke="currentColor" stroke-width="2"/></svg>
  </div>

  <!-- Terminal/Code icon -->
  <div class="floating-icon" style="top: 5%; left: 45%; --delay: 2s; --duration: 7.2s;">
    <svg viewBox="0 0 48 48" class="w-10 h-10 text-emerald-400/20"><rect x="6" y="10" width="36" height="28" rx="3" fill="none" stroke="currentColor" stroke-width="2"/><path d="M14 22l6 4-6 4" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/><path d="M24 30h10" stroke="currentColor" stroke-width="2" stroke-linecap="round"/></svg>
  </div>

  <!-- Git branch icon -->
  <div class="floating-icon" style="top: 70%; left: 25%; --delay: 4s; --duration: 8.5s;">
    <svg viewBox="0 0 48 48" class="w-9 h-9 text-orange-400/20"><circle cx="18" cy="14" r="3" fill="none" stroke="currentColor" stroke-width="2"/><circle cx="30" cy="20" r="3" fill="none" stroke="currentColor" stroke-width="2"/><circle cx="18" cy="34" r="3" fill="none" stroke="currentColor" stroke-width="2"/><path d="M18 17v14M21 14h6c2 0 3 1 3 3" fill="none" stroke="currentColor" stroke-width="2"/></svg>
  </div>

  <!-- Cloud/Server icon -->
  <div class="floating-icon" style="top: 50%; left: 42%; --delay: 3.5s; --duration: 9s;">
    <svg viewBox="0 0 48 48" class="w-8 h-8 text-sky-400/15"><path d="M14 32h20a8 8 0 001-16 10 10 0 00-19 4 7 7 0 00-2 12z" fill="none" stroke="currentColor" stroke-width="2"/></svg>
  </div>

  <!-- API/Curly braces -->
  <div class="floating-icon" style="top: 85%; left: 50%; --delay: 1s; --duration: 7s;">
    <svg viewBox="0 0 48 48" class="w-10 h-10 text-indigo-400/20"><text x="24" y="30" text-anchor="middle" fill="currentColor" font-size="22" font-family="monospace">{}</text></svg>
  </div>

  <!-- Docker/Container icon -->
  <div class="floating-icon" style="top: 30%; right: 20%; --delay: 2.8s; --duration: 6.2s;">
    <svg viewBox="0 0 48 48" class="w-9 h-9 text-blue-300/20"><rect x="10" y="22" width="28" height="14" rx="3" fill="none" stroke="currentColor" stroke-width="2"/><rect x="14" y="25" width="4" height="4" fill="none" stroke="currentColor" stroke-width="1"/><rect x="20" y="25" width="4" height="4" fill="none" stroke="currentColor" stroke-width="1"/><rect x="26" y="25" width="4" height="4" fill="none" stroke="currentColor" stroke-width="1"/><rect x="32" y="25" width="4" height="4" fill="none" stroke="currentColor" stroke-width="1"/><path d="M10 22c0-6 4-9 7-11" fill="none" stroke="currentColor" stroke-width="2"/></svg>
  </div>

  <!-- Binary -->
  <div class="floating-icon" style="top: 90%; right: 30%; --delay: 4.5s; --duration: 8s;">
    <svg viewBox="0 0 48 48" class="w-8 h-8 text-gray-400/15"><text x="24" y="28" text-anchor="middle" fill="currentColor" font-size="11" font-family="monospace">01010</text></svg>
  </div>

  <!-- Hash/Route icon -->
  <div class="floating-icon" style="top: 45%; left: 70%; --delay: 0.5s; --duration: 7.8s;">
    <svg viewBox="0 0 48 48" class="w-8 h-8 text-pink-400/15"><text x="24" y="32" text-anchor="middle" fill="currentColor" font-size="24" font-family="monospace">#</text></svg>
  </div>

  <!-- TypeScript -->
  <div class="floating-icon" style="top: 12%; left: 70%; --delay: 3.8s; --duration: 6.5s;">
    <svg viewBox="0 0 48 48" class="w-9 h-9 text-blue-400/20"><rect x="8" y="8" width="32" height="32" rx="4" fill="none" stroke="currentColor" stroke-width="2"/><text x="24" y="30" text-anchor="middle" fill="currentColor" font-size="14" font-weight="bold" font-family="monospace">TS</text></svg>
  </div>

  <!-- Lambda/Function icon -->
  <div class="floating-icon" style="top: 65%; left: 60%; --delay: 2.2s; --duration: 7.3s;">
    <svg viewBox="0 0 48 48" class="w-8 h-8 text-amber-400/15"><text x="24" y="34" text-anchor="middle" fill="currentColor" font-size="28" font-family="serif" font-style="italic">λ</text></svg>
  </div>

  <!-- Angle brackets / HTML -->
  <div class="floating-icon" style="top: 20%; left: 85%; --delay: 1.5s; --duration: 8.2s;">
    <svg viewBox="0 0 48 48" class="w-9 h-9 text-orange-300/20"><text x="24" y="30" text-anchor="middle" fill="currentColor" font-size="16" font-family="monospace">&lt;/&gt;</text></svg>
  </div>

  <!-- Infinity/Loop -->
  <div class="floating-icon" style="top: 80%; left: 80%; --delay: 3s; --duration: 7.6s;">
    <svg viewBox="0 0 48 48" class="w-9 h-9 text-teal-400/15"><path d="M14 24c0-4 3-7 7-7s7 3 7 7-3 7-7 7-7-3-7-7M27 24c0-4 3-7 7-7s7 3 7 7-3 7-7 7-7-3-7-7" fill="none" stroke="currentColor" stroke-width="2"/></svg>
  </div>
</div>

<style>
  .floating-icon {
    position: absolute;
    animation: float var(--duration, 7s) ease-in-out infinite;
    animation-delay: var(--delay, 0s);
    opacity: 0;
    animation-fill-mode: backwards;
  }

  @keyframes float {
    0% {
      transform: translateY(0px) rotate(0deg);
      opacity: 1;
    }
    25% {
      transform: translateY(-15px) rotate(3deg);
    }
    50% {
      transform: translateY(-8px) rotate(-2deg);
      opacity: 0.7;
    }
    75% {
      transform: translateY(-20px) rotate(2deg);
    }
    100% {
      transform: translateY(0px) rotate(0deg);
      opacity: 1;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .floating-icon {
      animation: none;
      opacity: 0.5;
    }
  }
</style>

<script>
  const container = document.querySelector('.hero-icons-container');
  const icons = document.querySelectorAll('.floating-icon');

  container?.parentElement?.addEventListener('mousemove', (e) => {
    const rect = container.getBoundingClientRect();
    const mouseX = (e.clientX - rect.left) / rect.width - 0.5;
    const mouseY = (e.clientY - rect.top) / rect.height - 0.5;

    icons.forEach((icon, i) => {
      const depth = 0.5 + (i % 3) * 0.3;
      const moveX = mouseX * 30 * depth;
      const moveY = mouseY * 20 * depth;
      (icon as HTMLElement).style.transform = `translate(${moveX}px, ${moveY}px)`;
    });
  });

  container?.parentElement?.addEventListener('mouseleave', () => {
    icons.forEach((icon) => {
      (icon as HTMLElement).style.transform = '';
    });
  });
</script>
