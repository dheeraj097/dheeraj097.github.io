---
interface Props {
  title: string;
  description: string;
  tech: string[];
  link?: string;
}

const { title, description, tech, link } = Astro.props;
---

<div class="project-card group relative bg-gray-900/50 border border-gray-800 rounded-xl p-6
            transition-all duration-300 ease-out
            hover:border-accent/40 hover:bg-gray-900/80 hover:-translate-y-2
            hover:shadow-xl hover:shadow-accent/10">
  <div class="flex items-start justify-between mb-3">
    <div class="p-2 bg-accent/10 rounded-lg text-accent group-hover:bg-accent/20 transition-colors duration-300">
      <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 7v10a2 2 0 002 2h14a2 2 0 002-2V9a2 2 0 00-2-2h-6l-2-2H5a2 2 0 00-2 2z" />
      </svg>
    </div>
    {link && (
      <a href={link} target="_blank" rel="noopener noreferrer"
         class="text-gray-500 hover:text-accent-light transition-colors">
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
        </svg>
      </a>
    )}
  </div>

  <h3 class="text-lg font-semibold text-gray-100 mb-2 group-hover:text-accent-light transition-colors duration-300">
    {title}
  </h3>
  <p class="text-gray-400 text-sm leading-relaxed mb-4">{description}</p>

  <div class="flex flex-wrap gap-2">
    {tech.map((t) => (
      <span class="text-xs px-2 py-1 bg-gray-800 text-gray-400 rounded-md font-mono
                   group-hover:bg-accent/10 group-hover:text-accent-light transition-colors duration-300">
        {t}
      </span>
    ))}
  </div>
</div>
