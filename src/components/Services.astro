---
import { services } from '../lib/content';

const icons: Record<string, string> = {
  code: '<path d="m16 18 6-6-6-6" /><path d="m8 6-6 6 6 6" />',
  layout: '<rect width="18" height="18" x="3" y="3" rx="2" /><path d="M3 9h18M9 21V9" />',
  server: '<rect width="20" height="8" x="2" y="2" rx="2" /><rect width="20" height="8" x="2" y="14" rx="2" /><path d="M6 6h.01M6 18h.01" />',
  rocket: '<path d="M4.5 16.5c-1.5 1.26-2 5-2 5s3.74-.5 5-2c.71-.84.7-2.13-.09-2.91a2.18 2.18 0 0 0-2.91-.09z" /><path d="m12 15-3-3a22 22 0 0 1 2-3.95A12.88 12.88 0 0 1 22 2c0 2.72-.78 7.5-6 11a22.35 22.35 0 0 1-4 2z" />',
};
---

<section id="services" class="scroll-mt-20 py-16 sm:py-24">
  <div class="container-section">
    <div class="mb-12 max-w-2xl">
      <p class="mb-3 text-sm font-semibold uppercase tracking-widest text-brand-600 dark:text-brand-400">Services</p>
      <h2 class="section-heading">How I can help</h2>
      <p class="mt-4 text-lg text-slate-600 dark:text-slate-300">
        Whether you need a new product built or an existing one improved, I can take it from concept to production.
      </p>
    </div>

    <div class="grid gap-6 sm:grid-cols-2">
      {services.map((service) => (
        <div class="card flex gap-5">
          <div class="flex h-12 w-12 flex-none items-center justify-center rounded-xl bg-brand-50 text-brand-600 dark:bg-brand-500/10 dark:text-brand-400">
            <svg
              xmlns="http://www.w3.org/2000/svg"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
              class="h-6 w-6"
              aria-hidden="true"
            >
              <Fragment set:html={icons[service.icon]} />
            </svg>
          </div>
          <div>
            <h3 class="text-lg font-semibold text-slate-900 dark:text-white">{service.title}</h3>
            <p class="mt-2 text-slate-600 dark:text-slate-300">{service.description}</p>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
