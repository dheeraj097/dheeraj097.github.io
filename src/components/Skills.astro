---
import { skillGroups } from '../lib/content';
---

<section id="skills" class="scroll-mt-20 py-16 sm:py-24">
  <div class="container-section">
    <div class="mb-12 max-w-2xl">
      <p class="mb-3 text-sm font-semibold uppercase tracking-widest text-brand-600 dark:text-brand-400">Skills</p>
      <h2 class="section-heading">Tools & technologies I work with</h2>
      <p class="mt-4 text-lg text-slate-600 dark:text-slate-300">
        A versatile, modern toolkit spanning the full stack — from interface to infrastructure.
      </p>
    </div>

    <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-4">
      {skillGroups.map((group) => (
        <div class="card">
          <h3 class="mb-4 text-lg font-semibold text-slate-900 dark:text-white">
            {group.title}
          </h3>
          <ul class="flex flex-wrap gap-2">
            {group.skills.map((skill) => (
              <li class="rounded-full border border-slate-200 bg-slate-50 px-3 py-1 text-sm text-slate-700 dark:border-white/10 dark:bg-white/5 dark:text-slate-200">
                {skill}
              </li>
            ))}
          </ul>
        </div>
      ))}
    </div>
  </div>
</section>
