---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="404 - Page Not Found | Dheeraj" description="The page you're looking for doesn't exist.">
  <section class="min-h-[70vh] flex items-center justify-center">
    <div class="section-container text-center">
      <h1 class="text-6xl sm:text-8xl font-bold gradient-text mb-4">404</h1>
      <p class="text-xl text-gray-400 mb-8">The page you're looking for doesn't exist.</p>
      <a href="/"
         class="px-6 py-3 bg-accent hover:bg-accent-light text-primary-950 font-semibold rounded-lg
                transition-all duration-300 hover:shadow-lg hover:shadow-accent/25">
        Go Home
      </a>
    </div>
  </section>
</BaseLayout>
