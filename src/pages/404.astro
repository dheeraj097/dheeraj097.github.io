---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---

<BaseLayout title="404 — Page Not Found">
  <Header />
  <main id="main" class="flex min-h-[60vh] items-center justify-center">
    <div class="container-section text-center">
      <h1 class="text-6xl font-bold text-brand-600 dark:text-brand-400 sm:text-8xl">404</h1>
      <p class="mt-4 text-xl text-slate-600 dark:text-slate-300">Page not found</p>
      <a href="/" class="mt-8 inline-block rounded-lg bg-brand-600 px-6 py-3 text-sm font-semibold text-white transition-colors hover:bg-brand-700">
        Go home
      </a>
    </div>
  </main>
  <Footer />
</BaseLayout>
