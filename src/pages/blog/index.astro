---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog'))
  .filter((post) => !post.data.draft)
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

function getReadingTime(content: string): string {
  const words = content.split(/\s+/).length;
  return `${Math.ceil(words / 200)} min read`;
}
---

<BaseLayout title="Blog — Dheeraj Dagar" description="Technical articles about web development, architecture, and best practices.">
  <Header />
  <main id="main" class="py-16 sm:py-24">
    <div class="container-section">
      <div class="mb-12 max-w-2xl">
        <p class="mb-3 text-sm font-semibold uppercase tracking-widest text-brand-600 dark:text-brand-400">Blog</p>
        <h1 class="section-heading">Thoughts & articles</h1>
        <p class="mt-4 text-lg text-slate-600 dark:text-slate-300">
          Sharing insights from 10+ years of building production systems.
        </p>
      </div>

      {posts.length === 0 ? (
        <p class="text-slate-500 dark:text-slate-400">No posts yet. Check back soon!</p>
      ) : (
        <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
          {posts.map((post) => (
            <a href={`/blog/${post.slug}/`} class="card group flex flex-col">
              <div class="flex items-center gap-3 text-xs text-slate-500 dark:text-slate-400">
                <time datetime={post.data.date.toISOString()}>
                  {post.data.date.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}
                </time>
                <span class="h-1 w-1 rounded-full bg-slate-300 dark:bg-slate-600"></span>
                <span>{getReadingTime(post.body)}</span>
              </div>
              <h2 class="mt-3 text-lg font-semibold text-slate-900 group-hover:text-brand-600 dark:text-white dark:group-hover:text-brand-400 transition-colors">
                {post.data.title}
              </h2>
              <p class="mt-2 flex-1 text-sm text-slate-600 dark:text-slate-300 line-clamp-3">
                {post.data.description}
              </p>
              {post.data.tags && (
                <ul class="mt-4 flex flex-wrap gap-2">
                  {post.data.tags.map((tag) => (
                    <li class="rounded-md bg-slate-100 px-2 py-0.5 text-xs font-medium text-slate-600 dark:bg-white/5 dark:text-slate-300">
                      {tag}
                    </li>
                  ))}
                </ul>
              )}
            </a>
          ))}
        </div>
      )}
    </div>
  </main>
  <Footer />
</BaseLayout>
