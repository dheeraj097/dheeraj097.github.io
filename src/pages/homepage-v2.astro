    html.v2-js .v2-reveal { opacity: 1; transform: none; filter: none; }
  }
</style>

<script>
  const root = document.querySelector('.v2-root');
  if (root) {
    const reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    const clamp = (v: number, a: number, b: number) => Math.max(a, Math.min(b, v));

    // ----- reveal on scroll -----
    const revealEls = Array.from(document.querySelectorAll<HTMLElement>('.v2-reveal'));
    if (reduce) {
      revealEls.forEach((el) => el.classList.add('in'));
    } else {
      const io = new IntersectionObserver(
        (entries) => {
          entries.forEach((e) => {
            if (e.isIntersecting) {
              e.target.classList.add('in');
              io.unobserve(e.target);
            }
          });
        },
        { threshold: 0.15, rootMargin: '0px 0px -8% 0px' }
      );
      revealEls.forEach((el) => io.observe(el));
    }

    // ----- active rung (lights up the one near viewport center) -----
    const rungs = Array.from(document.querySelectorAll<HTMLElement>('.v2-rung'));
    const rungIo = new IntersectionObserver(
      (entries) => entries.forEach((e) => e.target.classList.toggle('active', e.isIntersecting)),
      { rootMargin: '-46% 0px -46% 0px', threshold: 0 }
    );
    rungs.forEach((el) => rungIo.observe(el));

    // ----- count-up stats -----
    const counters = Array.from(document.querySelectorAll<HTMLElement>('.v2-counter'));
    const runCount = (el: HTMLElement) => {
      const target = parseFloat(el.dataset.target || '0');
      const suffix = el.dataset.suffix || '';
      if (reduce) {
        el.textContent = target + suffix;
        return;
      }
      const dur = 1500;
      const t0 = performance.now();
      const step = (now: number) => {
        const t = Math.min((now - t0) / dur, 1);
        const eased = 1 - Math.pow(1 - t, 3);
        el.textContent = Math.round(target * eased) + suffix;
        if (t < 1) requestAnimationFrame(step);
      };
      requestAnimationFrame(step);
    };
    const cio = new IntersectionObserver(
      (entries) => {
        entries.forEach((e) => {
          if (e.isIntersecting) {
            runCount(e.target as HTMLElement);
            cio.unobserve(e.target);
          }
        });
      },
      { threshold: 0.6 }
    );
    counters.forEach((el) => cio.observe(el));

    // ----- hero spotlight -----
    const hero = document.getElementById('v2-hero');
    const spot = document.getElementById('v2-spotlight');
    if (hero && spot && !reduce) {
      hero.addEventListener(
        'pointermove',
        (ev) => {
          const r = hero.getBoundingClientRect();
          spot.style.setProperty('--mx', ev.clientX - r.left + 'px');
          spot.style.setProperty('--my', ev.clientY - r.top + 'px');
          spot.style.opacity = '1';
        },
        { passive: true }
      );
      hero.addEventListener('pointerleave', () => (spot.style.opacity = '0'));
    }

    // ----- scroll-driven: thread draw + comet + progress + spine fill + parallax -----
    const thread = document.getElementById('thread-path') as SVGPathElement | null;
    const comet = document.getElementById('v2-comet');
    const progress = document.getElementById('v2-progress');
    const spineWrap = document.getElementById('v2-spine');
    const spineFill = document.getElementById('v2-spine-fill');
    const icons = Array.from(document.querySelectorAll<HTMLElement>('.v2-icon'));
    let threadLen = thread ? thread.getTotalLength() : 0;
    let ticking = false;

    const update = () => {
      ticking = false;
      const st = window.scrollY || window.pageYOffset;
      const vh = window.innerHeight;
      const docH = document.documentElement.scrollHeight - vh;
      const p = docH > 0 ? clamp(st / docH, 0, 1) : 0;

      if (progress) progress.style.transform = 'scaleX(' + p + ')';

      if (thread) {
        thread.style.strokeDashoffset = String(1 - p);
        if (comet && threadLen) {
          const pt = thread.getPointAtLength(threadLen * p);
          const ctm = thread.getScreenCTM();
          if (ctm) {
            const sx = pt.x * ctm.a + pt.y * ctm.c + ctm.e;
            const sy = pt.x * ctm.b + pt.y * ctm.d + ctm.f;
            comet.style.transform = 'translate(' + sx + 'px,' + sy + 'px)';
            comet.style.opacity = p > 0.002 && p < 0.998 ? '1' : '0';
          }
        }
      }

      if (spineWrap && spineFill) {
        const r = spineWrap.getBoundingClientRect();
        const sp = clamp((vh * 0.5 - r.top) / r.height, 0, 1);
        const base = window.innerWidth >= 900 ? 'translateX(-50%) ' : '';
        spineFill.style.transform = base + 'scaleY(' + sp + ')';
      }

      if (!reduce) {
        for (const ic of icons) {
          const speed = parseFloat(ic.dataset.speed || '0');
          ic.style.transform = 'translate3d(0,' + (st * speed).toFixed(1) + 'px,0)';
        }
      }
    };

    const onScroll = () => {
      if (!ticking) {
        ticking = true;
        requestAnimationFrame(update);
      }
    };

    const recalc = () => {
      threadLen = thread ? thread.getTotalLength() : 0;
      update();
    };

    window.addEventListener('scroll', onScroll, { passive: true });
    window.addEventListener('resize', recalc, { passive: true });
    window.addEventListener('load', recalc);
    update();
  }
</script>
