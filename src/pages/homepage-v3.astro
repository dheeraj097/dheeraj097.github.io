  .v3-camp-company { font-size: .92rem; font-weight: 600; color: #6ee7b7; }
  .v3-camp-desc { margin-top: 9px; font-size: .9rem; line-height: 1.55; color: #a7d3bf; }
  .v3-camp-high { margin-top: 10px; display: flex; gap: 8px; font-size: .86rem; line-height: 1.45; color: #d1fae5; }
  .v3-camp-high svg { flex: none; margin-top: 2px; color: #a3e635; }
