  .v3-avatar-ring { position: relative; width: 100%; aspect-ratio: 1; border-radius: 50%; padding: 10px; background: conic-gradient(from 180deg,#bef264,#34d399,#fcd34d,#bef264); box-shadow: 0 30px 60px -20px rgba(0,0,0,.7), 0 0 0 1px rgba(163,230,53,.2); will-change: transform; }
