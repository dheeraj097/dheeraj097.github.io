  .v3-eyebrow { display: inline-flex; align-items: center; gap: 9px; font-size: 13px; font-weight: 600; letter-spacing: .14em; text-transform: uppercase; color: #bef264; }
  .v3-title { font-family: 'Space Grotesk', sans-serif; font-weight: 700; line-height: .98; letter-spacing: -.03em; font-size: clamp(2.6rem,8vw,5.6rem); margin: 18px 0 0; color: #f0fff8; }
