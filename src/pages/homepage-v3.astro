  html:not(.v3-js) .v3-camp { opacity: 1; position: relative; width: auto; margin: 12px 0; }

  .v3-hud { position: absolute; left: clamp(16px,4vw,40px); top: 50%; transform: translateY(-50%); z-index: 6; display: flex; flex-direction: column; align-items: center; gap: 10px; pointer-events: none; }
  .v3-hud-label { writing-mode: vertical-rl; font-size: 10px; letter-spacing: .25em; text-transform: uppercase; color: #7fae97; }
  .v3-gauge { width: 6px; height: 200px; border-radius: 999px; background: rgba(255,255,255,.1); overflow: hidden; display: flex; align-items: flex-end; }
  .v3-gauge-fill { width: 100%; height: 0%; border-radius: 999px; background: linear-gradient(180deg,#fcd34d,#34d399,#a3e635); box-shadow: 0 0 12px rgba(163,230,53,.7); }
  .v3-elev { font-family: 'Space Grotesk',sans-serif; font-size: 13px; font-weight: 600; color: #eafff5; }

  .v3-stage-hint { position: absolute; bottom: 18px; left: 50%; transform: translateX(-50%); z-index: 6; font-size: 11px; letter-spacing: .2em; text-transform: uppercase; color: #7fae97; animation: v3-bob 2s ease-in-out infinite; }
  @keyframes v3-bob { 0%,100% { transform: translate(-50%,0); } 50% { transform: translate(-50%,6px); } }

  /* ---------- GEAR ---------- */
  .v3-gear-section { position: relative; z-index: 2; padding: 90px 0; }
  .v3-gear-grid { display: flex; flex-wrap: wrap; gap: 12px; justify-content: center; }
  .v3-gear-item { display: inline-flex; align-items: center; gap: 9px; padding: 11px 18px; border-radius: 999px; font-size: 14px; font-weight: 500; color: #d1fae5; background: rgba(255,255,255,.04); border: 1px solid rgba(163,230,53,.18); transition: transform .25s, border-color .25s, background .25s, color .25s, opacity .8s, filter .8s; }
  .v3-gear-item svg { color: #a3e635; }
  .v3-gear-item:hover { transform: translateY(-3px); border-color: rgba(163,230,53,.55); background: rgba(52,211,153,.1); color: #fff; }

  /* ---------- STATS ---------- */
  .v3-stats-section { position: relative; z-index: 2; padding: 30px 0 70px; }
  .v3-stats { display: grid; grid-template-columns: repeat(2,1fr); gap: 24px; padding: 38px clamp(20px,4vw,44px); border-radius: 26px; background: linear-gradient(180deg, rgba(13,40,26,.7), rgba(7,22,14,.66)); border: 1px solid rgba(163,230,53,.16); backdrop-filter: blur(12px); }
  .v3-stat { text-align: center; }
  .v3-stat-num { display: block; font-family: 'Space Grotesk',sans-serif; font-weight: 700; font-size: clamp(2.1rem,6vw,3.3rem); line-height: 1; background: linear-gradient(110deg,#bef264,#34d399,#fcd34d); -webkit-background-clip: text; background-clip: text; color: transparent; }
  .v3-stat-label { display: block; margin-top: 10px; font-size: .85rem; color: #9fcbb5; }

  /* ---------- CTA ---------- */
  .v3-cta-section { position: relative; z-index: 2; padding: 30px 0 90px; }
  .v3-cta-panel { position: relative; overflow: hidden; padding: clamp(40px,6vw,76px) clamp(24px,5vw,60px) clamp(70px,8vw,96px); border-radius: 30px; text-align: center; background: linear-gradient(160deg, rgba(52,211,153,.16), rgba(20,83,45,.18) 60%, rgba(255,255,255,.02)), rgba(7,22,14,.6); border: 1px solid rgba(163,230,53,.2); backdrop-filter: blur(12px); }
  .v3-cta-trees { position: absolute; left: 0; right: 0; bottom: 0; height: 90px; color: #06291b; opacity: .9; }
  .v3-cta-trees svg { width: 100%; height: 100%; }
  .v3-cta-title { position: relative; font-family: 'Space Grotesk',sans-serif; font-weight: 700; font-size: clamp(1.7rem,5vw,2.9rem); letter-spacing: -.02em; color: #f0fff8; margin: 12px 0 0; }
  .v3-cta-sub { position: relative; max-width: 520px; margin: 14px auto 0; color: #a7d3bf; line-height: 1.65; }
  .v3-cta-actions { position: relative; margin-top: 30px; display: flex; flex-wrap: wrap; gap: 16px; align-items: center; justify-content: center; }
  .v3-socials { display: flex; gap: 10px; }
  .v3-social { display: grid; place-items: center; width: 46px; height: 46px; border-radius: 14px; color: #d1fae5; background: rgba(255,255,255,.05); border: 1px solid rgba(163,230,53,.2); transition: .25s; }
  .v3-social:hover { transform: translateY(-3px); color: #fff; border-color: rgba(163,230,53,.6); background: rgba(52,211,153,.12); }
  .v3-foot { position: relative; margin-top: 34px; font-size: 13px; color: #5f876f; }

  /* ---------- desktop ---------- */
  @media (min-width: 768px) {
    .v3-hero-grid { grid-template-columns: 1.25fr .9fr; gap: 56px; }
    .v3-hero-avatar { width: min(38vw, 380px); }
    .v3-stats { grid-template-columns: repeat(4,1fr); }
  }

  /* ---------- mobile camps: bottom sheet ---------- */
  @media (max-width: 767px) {
    html.v3-js .v3-camp { left: 50% !important; top: auto !important; bottom: 4%; width: 90vw; transform: translateX(-50%) translateY(20px); }
    html.v3-js .v3-camp .v3-camp-node { display: none; }
    html.v3-js .v3-camp.active { transform: translateX(-50%) translateY(0); }
    html.v3-js .v3-camp:not(.is-current) { opacity: 0; pointer-events: none; }
    .v3-hud { display: none; }
    .v3-mountain { height: 70%; bottom: 8%; }
  }

  /* ---------- reduced motion ---------- */
  @media (prefers-reduced-motion: reduce) {
    .v3-leaf-inner, .v3-avatar-orbit, .v3-wheel, .v3-stage-hint, .v3-stat-num { animation: none !important; }
    html.v3-js .v3-reveal { opacity: 1; transform: none; filter: none; }
    .v3-expedition { height: auto; }
    .v3-stage { position: relative; height: auto; padding: 80px 0; }
    html.v3-js .v3-camp { position: relative; opacity: 1; left: auto !important; top: auto !important; transform: none !important; width: min(560px,90vw); margin: 14px auto; }
    html.v3-js .v3-camp .v3-camp-node { display: none; }
    .v3-mountain { position: relative; transform: none; left: auto; margin: 0 auto 30px; display: block; height: auto; width: min(560px,90vw); }
  }
</style>

<script>
  const root = document.querySelector('.v3-root');
  if (root) {
    const reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    const clamp = (v: number, a: number, b: number) => Math.max(a, Math.min(b, v));

    // reveals
    const revealEls = Array.from(document.querySelectorAll<HTMLElement>('.v3-reveal'));
    if (reduce) revealEls.forEach((el) => el.classList.add('in'));
    else {
      const io = new IntersectionObserver((entries) => {
        entries.forEach((e) => { if (e.isIntersecting) { e.target.classList.add('in'); io.unobserve(e.target); } });
      }, { threshold: 0.15, rootMargin: '0px 0px -8% 0px' });
      revealEls.forEach((el) => io.observe(el));
    }

    // count-up
    const counters = Array.from(document.querySelectorAll<HTMLElement>('.v3-counter'));
    const runCount = (el: HTMLElement) => {
      const target = parseFloat(el.dataset.target || '0');
      const suffix = el.dataset.suffix || '';
      if (reduce) { el.textContent = target + suffix; return; }
      const dur = 1500; const t0 = performance.now();
      const step = (now: number) => {
        const t = Math.min((now - t0) / dur, 1);
        const eased = 1 - Math.pow(1 - t, 3);
        el.textContent = Math.round(target * eased) + suffix;
        if (t < 1) requestAnimationFrame(step);
      };
      requestAnimationFrame(step);
    };
    const cio = new IntersectionObserver((entries) => {
      entries.forEach((e) => { if (e.isIntersecting) { runCount(e.target as HTMLElement); cio.unobserve(e.target); } });
    }, { threshold: 0.6 });
    counters.forEach((el) => cio.observe(el));

    // hero parallax (pointer + scroll)
    const depthEls = Array.from(document.querySelectorAll<HTMLElement>('[data-depth]'));
    const hero = document.getElementById('v3-hero');
    let mx = 0, my = 0;
    if (hero && !reduce) {
      hero.addEventListener('pointermove', (ev) => {
        const r = hero.getBoundingClientRect();
        mx = (ev.clientX - r.left) / r.width - 0.5;
        my = (ev.clientY - r.top) / r.height - 0.5;
        onScroll();
      }, { passive: true });
    }

    // ---- pinned expedition ----
    const wrap = document.getElementById('expedition');
    const stage = wrap?.querySelector<HTMLElement>('.v3-stage') || null;
    const trail = document.getElementById('v3-trail') as SVGPathElement | null;
    const hiker = document.getElementById('v3-hiker') as SVGGElement | null;
    const gauge = document.getElementById('v3-gauge-fill');
    const elev = document.getElementById('v3-elev');
    const campEls = Array.from(document.querySelectorAll<HTMLElement>('.v3-camp'));
    let trailLen = trail ? trail.getTotalLength() : 0;
    const MAX_ELEV = 4810; // a nod to Mont Blanc

    // place each camp node + card along the trail
    const placeCamps = () => {
      if (!trail || !stage || reduce) return;
      const ctm = trail.getScreenCTM();
      if (!ctm) return;
      const sr = stage.getBoundingClientRect();
      const w = sr.width;
      campEls.forEach((camp) => {
        const t = parseFloat(camp.dataset.t || '0');
        const pt = trail.getPointAtLength(trailLen * t);
        const sx = pt.x * ctm.a + pt.y * ctm.c + ctm.e - sr.left;
        const sy = pt.x * ctm.b + pt.y * ctm.d + ctm.f - sr.top;
        const node = camp.querySelector<HTMLElement>('.v3-camp-node');
        const card = camp.querySelector<HTMLElement>('.v3-camp-card');
        if (node) { node.style.left = sx + 'px'; node.style.top = sy + 'px'; }
        // choose side with more room
        const toRight = sx < w * 0.5;
        const cw = card ? card.offsetWidth : 300;
        let cx = toRight ? sx + 26 : sx - 26 - cw;
        cx = clamp(cx, 12, w - cw - 12);
        camp.style.left = cx + 'px';
        // vertical: center card on node, clamp into view
        const ch = card ? card.offsetHeight : 180;
        let cy = clamp(sy - ch / 2, 84, sr.height - ch - 16);
        camp.style.top = cy + 'px';
      });
    };

    let ticking = false;
    const update = () => {
      ticking = false;
      const st = window.scrollY || window.pageYOffset;
      const vh = window.innerHeight;
      const docH = document.documentElement.scrollHeight - vh;
      const gp = docH > 0 ? clamp(st / docH, 0, 1) : 0;
      const progress = document.getElementById('v3-progress');
      if (progress) progress.style.transform = 'scaleX(' + gp + ')';

      // hero parallax
      if (!reduce) {
        for (const el of depthEls) {
          const d = parseFloat(el.dataset.depth || '0');
          const ty = (el.closest('#v3-hero') ? st * d * 0.6 : 0);
          el.style.transform = `translate3d(${(mx * d * 60).toFixed(1)}px, ${(my * d * 40 - ty).toFixed(1)}px, 0)`;
        }
      }

      // pinned climb progress
      if (wrap && stage && !reduce) {
        const rect = wrap.getBoundingClientRect();
        const scrollable = wrap.offsetHeight - vh;
        const p = scrollable > 0 ? clamp(-rect.top / scrollable, 0, 1) : 0;

        if (trail) trail.style.strokeDashoffset = String(1 - p);
        if (hiker && trailLen) {
          const pt = trail!.getPointAtLength(trailLen * p);
          hiker.setAttribute('transform', `translate(${pt.x} ${pt.y})`);
        }
        if (gauge) gauge.style.height = (p * 100).toFixed(1) + '%';
        if (elev) elev.textContent = Math.round(p * MAX_ELEV).toLocaleString() + ' m';

        // camp activation + current (for mobile bottom sheet)
        let currentIdx = -1;
        campEls.forEach((camp) => {
          const t = parseFloat(camp.dataset.t || '0');
          const on = p >= t - 0.02;
          camp.classList.toggle('active', on);
          if (on) currentIdx = parseInt(camp.dataset.index || '-1', 10);
        });
        campEls.forEach((camp) => {
          camp.classList.toggle('is-current', parseInt(camp.dataset.index || '-1', 10) === currentIdx);
        });
      }
    };

    const onScroll = () => { if (!ticking) { ticking = true; requestAnimationFrame(update); } };
    const recalc = () => { trailLen = trail ? trail.getTotalLength() : 0; placeCamps(); update(); };

    window.addEventListener('scroll', onScroll, { passive: true });
    window.addEventListener('resize', recalc, { passive: true });
    window.addEventListener('load', recalc);
    recalc();
  }
</script>
