---
import BaseLayout from '../layouts/BaseLayout.astro';
import HeroSVG from '../components/HeroSVG.astro';
import SkillCard from '../components/SkillCard.astro';
import ProjectCard from '../components/ProjectCard.astro';

const skills = [
  { name: 'PHP', icon: '<svg viewBox="0 0 48 48" class="w-10 h-10 mx-auto"><ellipse cx="24" cy="24" rx="22" ry="14" fill="none" stroke="currentColor" stroke-width="2"/><text x="24" y="29" text-anchor="middle" fill="currentColor" font-size="14" font-weight="bold" font-family="monospace">PHP</text></svg>', color: '#777BB4' },
  { name: 'Laravel', icon: '<svg viewBox="0 0 48 48" class="w-10 h-10 mx-auto"><path d="M12 14l12-6 12 6v18l-12 6-12-6V14z" fill="none" stroke="currentColor" stroke-width="2"/><path d="M24 8v28M12 14l12 6 12-6" fill="none" stroke="currentColor" stroke-width="2"/></svg>', color: '#FF2D20' },
  { name: 'MySQL', icon: '<svg viewBox="0 0 48 48" class="w-10 h-10 mx-auto"><ellipse cx="24" cy="14" rx="14" ry="6" fill="none" stroke="currentColor" stroke-width="2"/><path d="M10 14v20c0 3.3 6.3 6 14 6s14-2.7 14-6V14" fill="none" stroke="currentColor" stroke-width="2"/><path d="M10 24c0 3.3 6.3 6 14 6s14-2.7 14-6" fill="none" stroke="currentColor" stroke-width="2"/></svg>', color: '#4479A1' },
  { name: 'React', icon: '<svg viewBox="0 0 48 48" class="w-10 h-10 mx-auto"><circle cx="24" cy="24" r="4" fill="currentColor"/><ellipse cx="24" cy="24" rx="18" ry="7" fill="none" stroke="currentColor" stroke-width="1.5"/><ellipse cx="24" cy="24" rx="18" ry="7" fill="none" stroke="currentColor" stroke-width="1.5" transform="rotate(60 24 24)"/><ellipse cx="24" cy="24" rx="18" ry="7" fill="none" stroke="currentColor" stroke-width="1.5" transform="rotate(120 24 24)"/></svg>', color: '#61DAFB' },
  { name: 'Node.js', icon: '<svg viewBox="0 0 48 48" class="w-10 h-10 mx-auto"><path d="M24 6l16 9.2v18.4L24 42 8 33.6V15.2L24 6z" fill="none" stroke="currentColor" stroke-width="2"/><text x="24" y="28" text-anchor="middle" fill="currentColor" font-size="10" font-weight="bold" font-family="monospace">N</text></svg>', color: '#339933' },
  { name: 'JavaScript', icon: '<svg viewBox="0 0 48 48" class="w-10 h-10 mx-auto"><rect x="8" y="8" width="32" height="32" rx="4" fill="none" stroke="currentColor" stroke-width="2"/><text x="24" y="30" text-anchor="middle" fill="currentColor" font-size="14" font-weight="bold" font-family="monospace">JS</text></svg>', color: '#F7DF1E' },
  { name: 'TypeScript', icon: '<svg viewBox="0 0 48 48" class="w-10 h-10 mx-auto"><rect x="8" y="8" width="32" height="32" rx="4" fill="none" stroke="currentColor" stroke-width="2"/><text x="24" y="30" text-anchor="middle" fill="currentColor" font-size="14" font-weight="bold" font-family="monospace">TS</text></svg>', color: '#3178C6' },
  { name: 'MongoDB', icon: '<svg viewBox="0 0 48 48" class="w-10 h-10 mx-auto"><path d="M24 6c-4 8-12 12-12 22 0 6 5.4 14 12 14s12-8 12-14c0-10-8-14-12-22z" fill="none" stroke="currentColor" stroke-width="2"/><path d="M24 6v36" stroke="currentColor" stroke-width="1.5"/></svg>', color: '#47A248' },
  { name: 'Redis', icon: '<svg viewBox="0 0 48 48" class="w-10 h-10 mx-auto"><path d="M8 24l16-10 16 10-16 10L8 24z" fill="none" stroke="currentColor" stroke-width="2"/><path d="M8 30l16 10 16-10" fill="none" stroke="currentColor" stroke-width="2"/><path d="M8 36l16 10 16-10" fill="none" stroke="currentColor" stroke-width="2"/></svg>', color: '#DC382D' },
  { name: 'Docker', icon: '<svg viewBox="0 0 48 48" class="w-10 h-10 mx-auto"><rect x="10" y="22" width="28" height="16" rx="3" fill="none" stroke="currentColor" stroke-width="2"/><rect x="14" y="26" width="4" height="4" fill="none" stroke="currentColor" stroke-width="1"/><rect x="20" y="26" width="4" height="4" fill="none" stroke="currentColor" stroke-width="1"/><rect x="26" y="26" width="4" height="4" fill="none" stroke="currentColor" stroke-width="1"/><rect x="32" y="26" width="4" height="4" fill="none" stroke="currentColor" stroke-width="1"/><rect x="14" y="32" width="4" height="4" fill="none" stroke="currentColor" stroke-width="1"/><rect x="20" y="32" width="4" height="4" fill="none" stroke="currentColor" stroke-width="1"/><path d="M10 22c0-6 4-10 8-12" fill="none" stroke="currentColor" stroke-width="2"/></svg>', color: '#2496ED' },
  { name: 'AWS', icon: '<svg viewBox="0 0 48 48" class="w-10 h-10 mx-auto"><path d="M8 28c4 4 10 6 16 6s12-2 16-6" fill="none" stroke="currentColor" stroke-width="2"/><path d="M14 20l10-8 10 8" fill="none" stroke="currentColor" stroke-width="2"/><path d="M24 12v16" stroke="currentColor" stroke-width="2"/></svg>', color: '#FF9900' },
  { name: 'Git', icon: '<svg viewBox="0 0 48 48" class="w-10 h-10 mx-auto"><circle cx="18" cy="16" r="3" fill="none" stroke="currentColor" stroke-width="2"/><circle cx="30" cy="24" r="3" fill="none" stroke="currentColor" stroke-width="2"/><circle cx="18" cy="34" r="3" fill="none" stroke="currentColor" stroke-width="2"/><path d="M18 19v12M21 16h6c2 0 3 1 3 3v2" fill="none" stroke="currentColor" stroke-width="2"/></svg>', color: '#F05032' },
];

const projects = [
  {
    title: 'Enterprise SaaS Platform',
    description: 'Built a multi-tenant SaaS application handling 50k+ daily active users with real-time notifications, role-based access, and automated billing.',
    tech: ['Laravel', 'React', 'MySQL', 'Redis', 'AWS'],
  },
  {
    title: 'E-Commerce Microservices',
    description: 'Architected a microservices-based e-commerce platform with event-driven communication, distributed caching, and horizontal scaling.',
    tech: ['Node.js', 'MongoDB', 'Docker', 'RabbitMQ', 'React'],
  },
  {
    title: 'Real-Time Analytics Dashboard',
    description: 'Developed a high-performance analytics engine processing millions of events daily with sub-second query responses and live data visualization.',
    tech: ['PHP', 'ClickHouse', 'WebSocket', 'Vue.js', 'Redis'],
  },
  {
    title: 'API Gateway & Auth Service',
    description: 'Designed and implemented a centralized API gateway with OAuth2/JWT authentication, rate limiting, and request transformation for 30+ microservices.',
    tech: ['Node.js', 'TypeScript', 'PostgreSQL', 'Docker', 'Nginx'],
  },
  {
    title: 'Content Management System',
    description: 'Created a headless CMS with a flexible content modeling system, multi-language support, versioning, and a React-based admin interface.',
    tech: ['Laravel', 'React', 'MySQL', 'ElasticSearch', 'S3'],
  },
  {
    title: 'DevOps Automation Pipeline',
    description: 'Implemented CI/CD pipelines with automated testing, blue-green deployments, infrastructure as code, and comprehensive monitoring.',
    tech: ['Docker', 'GitHub Actions', 'Terraform', 'AWS', 'Shell'],
  },
];
---

<BaseLayout
  title="Dheeraj | Backend-Heavy Fullstack Developer"
  description="Fullstack developer with 10+ years of experience in PHP, Laravel, React, Node.js, and cloud architecture. Specializing in scalable backend systems."
>
  <!-- JSON-LD Structured Data -->
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "Person",
    "name": "Dheeraj",
    "url": "https://dheeraj097.github.io",
    "jobTitle": "Fullstack Developer",
    "description": "Backend-heavy fullstack developer with 10+ years of experience",
    "knowsAbout": ["PHP", "Laravel", "MySQL", "React", "Node.js", "MongoDB", "AWS", "Docker"],
    "sameAs": [
      "https://github.com/dheeraj097",
      "https://linkedin.com/in/dheeraj097"
    ]
  })} />

  <!-- Hero Section -->
  <section class="relative min-h-[90vh] flex items-center justify-center overflow-hidden">
    <HeroSVG />

    <div class="section-container relative z-10 text-center">
      <div class="animate-fade-in">
        <p class="text-accent font-mono text-sm sm:text-base mb-4 tracking-wider">Hello, I'm</p>
        <h1 class="text-4xl sm:text-5xl md:text-7xl font-extrabold mb-6 text-balance">
          <span class="text-gray-100">Dheeraj</span>
        </h1>
        <h2 class="text-xl sm:text-2xl md:text-3xl font-light text-gray-300 mb-4">
          Backend-Heavy <span class="gradient-text font-semibold">Fullstack Developer</span>
        </h2>
        <p class="max-w-2xl mx-auto text-gray-400 text-base sm:text-lg mb-8 leading-relaxed">
          10+ years crafting scalable systems with PHP, Laravel, Node.js, and React.
          I build robust architectures that handle millions of requests.
        </p>

        <div class="flex items-center justify-center gap-4 flex-wrap">
          <a href="/#projects"
             class="px-6 py-3 bg-accent hover:bg-accent-light text-primary-950 font-semibold rounded-lg
                    transition-all duration-300 hover:shadow-lg hover:shadow-accent/25 hover:-translate-y-0.5">
            View My Work
          </a>
          <a href="/blog"
             class="px-6 py-3 border border-gray-700 hover:border-accent text-gray-300 hover:text-accent-light
                    font-medium rounded-lg transition-all duration-300 hover:-translate-y-0.5">
            Read Blog
          </a>
        </div>
      </div>

      <!-- Scroll indicator -->
      <div class="absolute bottom-8 left-1/2 -translate-x-1/2 animate-bounce">
        <svg class="w-6 h-6 text-gray-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 14l-7 7m0 0l-7-7m7 7V3" />
        </svg>
      </div>
    </div>
  </section>

  <!-- About Section -->
  <section id="about" class="py-20 sm:py-28">
    <div class="section-container">
      <div class="max-w-3xl mx-auto text-center">
        <h2 class="text-3xl sm:text-4xl font-bold mb-6">
          About <span class="gradient-text">Me</span>
        </h2>
        <p class="text-gray-300 text-lg leading-relaxed mb-6">
          I'm a passionate fullstack developer with over a decade of experience building web applications
          at scale. My expertise lies in backend architecture — designing systems that are reliable,
          performant, and maintainable.
        </p>
        <p class="text-gray-400 leading-relaxed mb-6">
          From monolithic PHP applications to distributed microservices, I've worked across the full
          spectrum of web development. I specialize in the LAMP and MERN stacks, with deep expertise
          in Laravel, database optimization, API design, and cloud infrastructure.
        </p>
        <p class="text-gray-400 leading-relaxed">
          When I'm not writing code, I enjoy sharing knowledge through my blog, contributing to
          open-source projects, and mentoring fellow developers.
        </p>
      </div>
    </div>
  </section>

  <!-- Skills Section -->
  <section id="skills" class="py-20 sm:py-28 bg-gray-900/20">
    <div class="section-container">
      <div class="text-center mb-12">
        <h2 class="text-3xl sm:text-4xl font-bold mb-4">
          Tech <span class="gradient-text">Stack</span>
        </h2>
        <p class="text-gray-400 max-w-2xl mx-auto">
          Technologies I've worked with extensively over 10+ years of building production systems.
        </p>
      </div>

      <div class="grid grid-cols-3 sm:grid-cols-4 md:grid-cols-6 gap-4">
        {skills.map((skill) => (
          <SkillCard name={skill.name} icon={skill.icon} color={skill.color} />
        ))}
      </div>
    </div>
  </section>

  <!-- Projects Section -->
  <section id="projects" class="py-20 sm:py-28">
    <div class="section-container">
      <div class="text-center mb-12">
        <h2 class="text-3xl sm:text-4xl font-bold mb-4">
          Featured <span class="gradient-text">Projects</span>
        </h2>
        <p class="text-gray-400 max-w-2xl mx-auto">
          A selection of projects showcasing my experience with complex backend systems and fullstack development.
        </p>
      </div>

      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6">
        {projects.map((project) => (
          <ProjectCard
            title={project.title}
            description={project.description}
            tech={project.tech}
          />
        ))}
      </div>
    </div>
  </section>

  <!-- Contact Section -->
  <section id="contact" class="py-20 sm:py-28 bg-gray-900/20">
    <div class="section-container">
      <div class="max-w-2xl mx-auto text-center">
        <h2 class="text-3xl sm:text-4xl font-bold mb-4">
          Let's <span class="gradient-text">Connect</span>
        </h2>
        <p class="text-gray-400 mb-8">
          I'm always open to discussing new projects, interesting ideas, or opportunities to collaborate.
        </p>

        <div class="flex items-center justify-center gap-4 flex-wrap">
          <a href="mailto:dheeraj097@gmail.com"
             class="px-6 py-3 bg-accent hover:bg-accent-light text-primary-950 font-semibold rounded-lg
                    transition-all duration-300 hover:shadow-lg hover:shadow-accent/25 hover:-translate-y-0.5
                    inline-flex items-center gap-2">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
            </svg>
            Say Hello
          </a>
          <a href="https://github.com/dheeraj097"
             target="_blank"
             rel="noopener noreferrer"
             class="px-6 py-3 border border-gray-700 hover:border-accent text-gray-300 hover:text-accent-light
                    font-medium rounded-lg transition-all duration-300 hover:-translate-y-0.5
                    inline-flex items-center gap-2">
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
              <path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/>
            </svg>
            GitHub
          </a>
          <a href="https://linkedin.com/in/dheeraj097"
             target="_blank"
             rel="noopener noreferrer"
             class="px-6 py-3 border border-gray-700 hover:border-accent text-gray-300 hover:text-accent-light
                    font-medium rounded-lg transition-all duration-300 hover:-translate-y-0.5
                    inline-flex items-center gap-2">
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
              <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
            </svg>
            LinkedIn
          </a>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
